{
  "id": "dynamic-graph-creation",
  "enabled": true,
  "isDefault": true,
  "label": "Dynamic Graph Creation",
  "role": "Dynamic Graph Creator",
  "shortDescription": "Generates OLO workflow graphs as JSON-only structured output and expands them inline at runtime",
  "emoji": "🧩",
  "designer": {
    "paletteGroup": "Agents",
    "searchKeywords": [
      "dynamic",
      "graph",
      "workflow",
      "json"
    ],
    "nodeSize": {
      "width": 300,
      "height": 120
    },
    "resizable": true,
    "draggable": true,
    "layout": {
      "originX": 80,
      "originY": 80,
      "columnGap": 360,
      "rowGap": 200,
      "columns": 4
    },
    "canvas": {
      "backgroundColor": "#3f3f46",
      "gridGap": 16,
      "edgeStroke": "#52525b",
      "selectionBorder": "#3b82f6",
      "minimapNodeColor": "#52525b"
    },
    "portColors": {
      "string": "#a3e635",
      "object": "#c084fc",
      "integer": "#38bdf8",
      "any": "#94a3b8",
      "number": "#38bdf8",
      "array": "#f472b6",
      "boolean": "#fb923c",
      "message": "#ef4444"
    },
    "nodeTypes": {
      "AGENT": {
        "emoji": "🧩",
        "typeLabel": "Agent",
        "inlineProperties": [
          {
            "id": "parameters",
            "widget": "WORKFLOW_PARAMETERS",
            "label": "Parameters"
          },
          {
            "id": "model",
            "widget": "MODEL_SELECTOR",
            "label": "Model"
          }
        ]
      },
      "END": {
        "emoji": "⏹",
        "typeLabel": "End",
        "description": "Workflow exit — maps a workflow variable to the caller result",
        "palette": {
          "name": "End",
          "category": "control"
        },
        "inlineProperties": [
          {
            "id": "outputVariable",
            "widget": "VARIABLE_SELECT",
            "label": "Output variable",
            "binding": "outputVariableMapping"
          }
        ]
      },
      "START": {
        "emoji": "▶",
        "typeLabel": "Start",
        "description": "Workflow entry — maps caller input to workflow variables",
        "palette": {
          "name": "Start",
          "category": "control"
        },
        "inlineProperties": [
          {
            "id": "inputVariables",
            "widget": "VARIABLE_CHECKLIST",
            "label": "Input variables",
            "binding": "inputVariableMappings"
          }
        ]
      }
    }
  },
  "queue": "oloQueue2",
  "workflowType": "olo",
  "runAgain": true,
  "childWorkflows": [],
  "availableAgents": [],
  "version": "1.0.0",
  "capability": {
    "name": "Dynamic Graph Creation",
    "description": "Generates OLO workflow graphs as JSON-only structured output and expands them inline at runtime",
    "tags": [
      "dynamic-graph",
      "json"
    ],
    "examples": [],
    "required_inputs": [
      "input"
    ],
    "required_outputs": [
      "output"
    ],
    "tool_requirements": [],
    "required_context": [
      "message",
      "generatedGraphJson"
    ]
  },
  "runtime": {
    "contractVersion": "1.0",
    "executionModel": "INLINE"
  },
  "inputs": {
    "message": {
      "schema": "string",
      "required": true,
      "populateState": true
    }
  },
  "state": {},
  "parameters": {
    "model": {
      "type": "string",
      "label": "Model",
      "description": "Default model identifier",
      "defaultValue": "",
      "required": false,
      "ui": {
        "widget": "MODEL_SELECTOR",
        "group": "Model Settings",
        "help": "Optional workflow default. Prefer the Model control on each Agent node.",
        "order": 2
      }
    },
    "temperature": {
      "type": "number",
      "label": "Temperature",
      "description": "Sampling temperature",
      "defaultValue": 0.2,
      "required": false,
      "validation": {
        "minimum": 0,
        "maximum": 2,
        "step": 0.1
      },
      "ui": {
        "widget": "SLIDER",
        "group": "Model Settings",
        "help": "Higher values increase response creativity.",
        "order": 3
      }
    },
    "systemPrompt": {
      "type": "string",
      "label": "System Prompt",
      "description": "System prompt for the agent",
      "defaultValue": "I am Rahul, {message}",
      "required": false,
      "ui": {
        "widget": "TEXTAREA",
        "group": "Model Settings",
        "help": "Include {message} to inject the workflow input into the system prompt.",
        "placeholder": "You are a helpful assistant…\n\n{message}",
        "order": 0
      }
    },
    "maxIterations": {
      "type": "integer",
      "label": "Max Iterations",
      "description": "Maximum agent reasoning iterations",
      "defaultValue": 10,
      "required": false,
      "validation": {
        "minimum": 1,
        "maximum": 100,
        "step": 1
      },
      "ui": {
        "widget": "NUMBER",
        "group": "Model Settings",
        "help": "Caps how many planner/tool loops the agent may run.",
        "order": 1
      }
    }
  },
  "nodes": [
    {
      "id": "start",
      "type": "START",
      "ports": [
        {
          "id": "out",
          "label": "message out",
          "schema": "message",
          "type": "message",
          "direction": "OUTPUT",
          "required": false,
          "minConnections": 0,
          "shortDescription": "Outgoing workflow message",
          "ui": {
            "position": "RIGHT",
            "color": "#ef4444"
          }
        }
      ],
      "reads": [
        "input.message"
      ],
      "writes": [],
      "configuration": {
        "inputVariableMappings": [
          "message"
        ],
        "designer": {
          "position": {
            "x": 80,
            "y": 80
          }
        }
      }
    },
    {
      "id": "graph-planner",
      "type": "AGENT",
      "ports": [
        {
          "id": "in",
          "label": "message in",
          "schema": "message",
          "type": "message",
          "acceptType": "message",
          "direction": "INPUT",
          "required": true,
          "minConnections": 1,
          "maxConnections": 1,
          "shortDescription": "Incoming workflow message",
          "ui": {
            "position": "LEFT",
            "color": "#ef4444"
          }
        },
        {
          "id": "out",
          "label": "message out",
          "schema": "message",
          "type": "message",
          "direction": "OUTPUT",
          "required": false,
          "minConnections": 0,
          "shortDescription": "Outgoing workflow message",
          "ui": {
            "position": "RIGHT",
            "color": "#ef4444"
          }
        }
      ],
      "execution": {
        "executionKind": "ACTIVITY",
        "executionModel": "INLINE",
        "routers": []
      },
      "reads": [],
      "writes": [],
      "configuration": {
        "dynamicGraphPlanner": true,
        "outputVariable": "generatedGraphJson",
        "maxInvalidJsonRetries": 3,
        "continueNodeId": "end",
        "designer": {
          "position": {
            "x": 440,
            "y": 80
          }
        }
      }
    },
    {
      "id": "end",
      "type": "END",
      "ports": [
        {
          "id": "in",
          "label": "message in",
          "schema": "message",
          "type": "message",
          "acceptType": "message",
          "direction": "INPUT",
          "required": true,
          "minConnections": 1,
          "maxConnections": 1,
          "shortDescription": "Incoming workflow message",
          "ui": {
            "position": "LEFT",
            "color": "#ef4444"
          }
        }
      ],
      "reads": [],
      "writes": [],
      "configuration": {
        "designer": {
          "position": {
            "x": 800,
            "y": 80
          }
        }
      }
    }
  ],
  "edges": [
    {
      "sourceNodeId": "start",
      "sourcePortId": "out",
      "targetNodeId": "graph-planner",
      "targetPortId": "in"
    },
    {
      "sourceNodeId": "graph-planner",
      "sourcePortId": "out",
      "targetNodeId": "end",
      "targetPortId": "in"
    }
  ],
  "variables": [
    {
      "name": "message",
      "type": "string",
      "description": "",
      "required": true,
      "scope": "READONLY_EXTERNAL",
      "metadata": {}
    },
    {
      "name": "generatedGraphJson",
      "type": "string",
      "description": "Model-produced workflow graph JSON",
      "required": false,
      "scope": "LOCAL",
      "metadata": {
        "role": "generated-graph"
      }
    },
    {
      "name": "generatedGraphJsonRetryCount",
      "type": "number",
      "description": "Invalid JSON retry counter for the dynamic graph planner",
      "required": false,
      "scope": "LOCAL",
      "metadata": {}
    },
    {
      "name": "generatedGraphJsonValidationError",
      "type": "string",
      "description": "Last validation error from generatedGraphJson, injected into planner retries",
      "required": false,
      "scope": "LOCAL",
      "metadata": {}
    },
    {
      "name": "ReturnValue",
      "type": "string",
      "description": "Workflow return message returned to the caller",
      "required": false,
      "scope": "LOCAL",
      "metadata": {
        "role": "return"
      }
    }
  ],
  "tools": [],
  "agents": [],
  "hooks": [],
  "modelProviders": [
    {
      "id": "model-provider",
      "provider": "local",
      "model": "llama3.2:latest",
      "configuration": {
        "baseUrl": "http://localhost:51435"
      }
    }
  ],
  "modelRouting": [
    {
      "id": "default-routing",
      "defaultProviderId": "model-provider",
      "rules": [],
      "metadata": {}
    }
  ],
  "extensions": [],
  "metadata": {
    "dynamicGraphCreation": {
      "outputVariable": "generatedGraphJson",
      "plannerNodeId": "graph-planner",
      "continueNodeId": "end"
    },
    "description": "Generates OLO workflow graphs as JSON-only structured output and expands them inline at runtime",
    "returnVariable": "ReturnValue",
    "plannerContext": {
      "selectedAgents": [],
      "selectedTools": [],
      "injectCapabilities": false,
      "selectedVariables": [
        "message"
      ],
      "injectAgents": false
